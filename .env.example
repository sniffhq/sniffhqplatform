# SniffHQ Platform Admin — Environment Variables
# Copy to .env and fill in all values before starting.

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
PLATFORM_SECRET_KEY=change-me-generate-a-real-key

# Platform admin login credentials
ADMIN_EMAIL=charles.brown@sniffhq.com
ADMIN_PASSWORD=change-me-strong-password

# Path to the SniffHQDemo codebase (shared app code used to init tenant DBs)
SNIFFHQ_APP_DIR=C:\SniffHQDemo

# Directory where tenant folders are created
TENANTS_DIR=C:\SniffHQ\tenants

# Starting port for tenant Waitress processes (increments per tenant)
BASE_PORT=8001

# Email — reuse same Zoho creds as SniffHQDemo
MAIL_SERVER=smtp.zoho.com
MAIL_PORT=587
MAIL_USERNAME=info@sniffhq.com
MAIL_PASSWORD=your-zoho-password
